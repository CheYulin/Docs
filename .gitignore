logs
# Local verification outputs (see results/README.md)
/results/*
!/results/README.md

# Large intermediate run artifacts under plans
/plans/**/runs/

# Local Python virtual environments
.venv*/
/.venv-fm/

# Python bytecode caches
*.pyc
__pycache__/

# ── workspace/observability generated artifacts ──
# Raw bpftrace traces (can be >100MB each)
workspace/observability/bpftrace/*_stacks.txt
workspace/observability/bpftrace/*_stacks.sym.txt
# Process memory maps
workspace/observability/bpftrace/*_maps.txt
# PID files
workspace/observability/bpftrace/*.pid
# Chart images (generated from csv data)
workspace/observability/perf/*.png

# ── workspace/reliability generated artifacts ──
# Binary Excel (generated by scripts from .tsv/.txt source)
workspace/reliability/*.xlsx
